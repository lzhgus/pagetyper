{
  "manifest_version": 3,
  "name": "PageTyper",
  "description": "Turn article pages into focused typing practice.",
  "version": "0.1.1",
  "action": {
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    },
    "default_popup": "src/popup.html",
    "default_title": "PageTyper"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "commands": {
    "toggle-typing-mode": {
      "suggested_key": {
        "default": "Alt+Shift+T",
        "mac": "Alt+Shift+T"
      },
      "description": "Toggle PageTyper typing mode"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["src/content.css"],
      "js": ["src/text-metrics.js", "src/reward-system.js", "src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "permissions": ["storage", "tabs"]
}
